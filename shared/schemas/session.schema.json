{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WebWardenSession",
  "type": "object",
  "required": ["categoryId", "domain", "deltaMs", "timestamp"],
  "properties": {
    "categoryId": { "type": "string" },
    "domain": { "type": "string" },
    "startMs": { "type": "integer" },
    "endMs": { "type": "integer" },
    "deltaMs": { "type": "integer", "minimum": 0 },
    "timestamp": { "type": "integer" }
  }
}
